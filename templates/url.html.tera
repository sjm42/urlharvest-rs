<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>IRC URL log</title>
    <script src="./static/theme.js"></script>
    <link rel="stylesheet" href="./static/theme.css">
</head>

<body>
    <fieldset class="theme-selector">
        <legend>Theme</legend>
        <label class="theme-option"><input type="radio" name="theme" value="system" checked> System</label>
        <label class="theme-option"><input type="radio" name="theme" value="light"> Light</label>
        <label class="theme-option"><input type="radio" name="theme" value="dark"> Dark</label>
    </fieldset>
    <h1>IRC URL log</h1>
    <h3>Last 7 days -- all timestamps are in EET time</h3>
    <p>Page updated {{last_change}}</p>
    <hr>
    <table>
        <tr>
            <th>ID</th>
            <th>Seen First</th>
            <th>Seen Last</th>
            <th>Seen#</th>
            <th>URL</th>
        </tr>
        {% for id_i in uniq_id -%}
        <tr>
            {% if uniq_seen_cnt[loop.index0] != "1" %}
            <td>{{id_i}}</td>
            <td><b>{{uniq_seen_first[loop.index0]}}</b></td>
            <td>{{uniq_seen_last[loop.index0]}}</td>
            <td><b>{{uniq_seen_cnt[loop.index0]}}</b></td>
            {% else %}
            <td>{{id_i}}</td>
            <td>{{uniq_seen_first[loop.index0]}}</td>
            <td>{{uniq_seen_last[loop.index0]}}</td>
            <td>1</td>
            {% endif %}
            <td>{{uniq_title[loop.index0]}}<br>
                <a href="{{uniq_url[loop.index0]}}">{{uniq_url[loop.index0]}}</a>
            </td>
        </tr>
        {% endfor %}
    </table>
</body>
</html>
