<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>#paskat_urlit URL log</title>
    <script src="/url2/static/theme.js"></script>
    <link rel="stylesheet" href="/url2/static/theme.css">
</head>

<body>
    <label class="theme-selector" for="theme-select">Theme:
        <select id="theme-select">
            <option value="system">System</option>
            <option value="light">Light</option>
            <option value="dark">Dark</option>
        </select>
    </label>
    <h1>#paskat_urlit URL log</h1>
    <h3>Last 7 days -- all timestamps are in EET time</h3>
    <p>Page updated {{last_change}}</p>
    <hr>
    <table>
        <tr>
            <th>ID</th>
            <th>Seen First</th>
            <th>Seen Last</th>
            <th>Seen#</th>
            <th>URL</th>
        </tr>
        {% for id_i in id -%}
        {% if channel[loop.index0] == "#paskat_urlit" -%}
        <tr>
            {% if seen_cnt[loop.index0] != "1" -%}
            <td>{{id_i}}</td>
            <td><b>{{seen_first[loop.index0]}}</b></td>
            <td>{{seen_last[loop.index0]}}</td>
            <td><b>{{seen_cnt[loop.index0]}}</b></td>
            {% else -%}
            <td>{{id_i}}</td>
            <td>{{seen_first[loop.index0]}}</td>
            <td>{{seen_last[loop.index0]}}</td>
            <td>1</td>
            {% endif -%}
            <td>{{title[loop.index0]}}<br>
                <a href="{{url[loop.index0]}}">{{url[loop.index0]}}</a>
            </td>
        </tr>
        {% endif -%}
        {% endfor -%}
    </table>
</body>
</html>
